#!name=机场签到
#!desc=69云与ikuuu机场每日签到。支持参数配置：在 静默运行 处填 # 即可静默运行，留空则正常弹出系统通知。
#!author=〈ザㄩメ火华
#!arguments=CRON定时69云:"0 9 * * *",CRON定时ikuuu:"0 9 * * *",静默运行:""
#!arguments-desc=CRON定时设置: 签到脚本的 CRON 表达式\n 静默运行: 静默运行 (填 # 则静默不通知，留空则正常弹出通知)

[Script]
69云签到 = type=cron, cronexp="{{{CRON定时69云}}}", script-path=https://raw.githubusercontent.com/loveyuwy/huohua/refs/heads/main/69yun.js,timeout=60,argument=silent={{{静默运行}}}
ikuuu签到 = type=cron, cronexp="{{{CRON定时ikuuu}}}", timeout=60,script-path=https://raw.githubusercontent.com/loveyuwy/huohua/refs/heads/main/ikuuu.js,argument=silent={{{静默运行}}}