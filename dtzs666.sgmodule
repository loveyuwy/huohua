#!name=豆图助手
#!desc=装b神器，解锁会员，去除截图录屏水印

[Rule]
DOMAIN,api2ltzszt.llun.cc,REJECT

[Script]
豆图助手 = type=http-response,pattern=^https?:\/\/api2ltzszt\.llun\.cc,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/loveyuwy/hao/refs/heads/main/dtzs.js,binary-body-mode=0,debug=1

[MITM]
hostname = %APPEND% api2ltzszt.llun.cc